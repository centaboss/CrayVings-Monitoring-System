# Server Configuration
PORT=3000
NODE_ENV=development

# PostgreSQL Configuration
PG_HOST=localhost
PG_PORT=5432
PG_DATABASE=crayvings_monitoring_system_db
PG_USER=postgres
PG_PASSWORD=your_password_here

# CORS - Add your frontend URLs here
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174

# Arduino Serial Configuration (optional)
ARDUINO_ENABLED=false
ARDUINO_PORT=COM3
ARDUINO_BAUD=19200
DEVICE_ID=ARDUINO_001
POLL_INTERVAL=1000

# =============================================================================
# SkySMS API Configuration
# =============================================================================
SKYSMS_API_KEY=your_skysms_api_key_here
SKYSMS_API_URL=https://skysms.skyio.site/api/v1

# SMS Cooldown Settings (in milliseconds)
# Critical alerts: minimum time between repeated SMS (default: 5 minutes = 300000)
SMS_COOLDOWN_MS=300000

# Warning alerts: minimum time between repeated SMS (default: 1 hour = 3600000)
WARNING_SMS_COOLDOWN_MS=3600000

# =============================================================================
# Hourly SMS Update Configuration
# =============================================================================
# Set to 'false' to disable hourly status updates (default: enabled)
HOURLY_SMS_ENABLED=true

# How often to send hourly updates in milliseconds (default: 1 hour = 3600000)
HOURLY_SMS_INTERVAL_MS=3600000

# =============================================================================
# Customizing SMS Messages
# =============================================================================
# To change SMS message text, edit the SMS_CONFIG object in server.cjs (lines ~30-80)
#
# Message templates use {{PLACEHOLDER}} syntax:
#   {{SENSOR}}     - Sensor name (e.g., TEMPERATURE, PH LEVEL)
#   {{NAME}}       - Recipient name
#   {{VALUE}}      - Current sensor reading
#   {{UNIT}}       - Unit (°C, %, or empty for pH)
#   {{THRESHOLD}}  - Threshold value that was crossed
#   {{TIME}}       - Timestamp in Philippines timezone
#
# For hourly updates:
#   {{TEMP}}       - Temperature reading
#   {{TEMP_STATUS}} - Temperature status (✅ Good, ⚠️ Warning, 🚨 Critical)
#   {{PH}}         - pH reading
#   {{PH_STATUS}}  - pH status
#   {{WATER}}      - Water level reading
#   {{WATER_STATUS}}- Water level status
#   {{SUMMARY}}    - Summary text (e.g., "All systems normal ✅")
#
# To change sensor display names or units, edit SMS_CONFIG.sensorNames and SMS_CONFIG.units
# To change SMS sender name, edit SMS_CONFIG.from (default: "CRAYVINGS")