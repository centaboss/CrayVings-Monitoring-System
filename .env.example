# Server Configuration
PORT=3000
NODE_ENV=development

# PostgreSQL Configuration
PG_HOST=localhost
PG_PORT=5432
PG_DATABASE=crayvings_monitoring_system_db
PG_USER=postgres
PG_PASSWORD=your_password_here

# CORS
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:3001

# Arduino Serial Configuration
ARDUINO_ENABLED=false
ARDUINO_PORT=COM3
ARDUINO_BAUD=19200
DEVICE_ID=ARDUINO_001
POLL_INTERVAL=1000

# Twilio SMS Configuration
# Get these credentials from: https://www.twilio.com/console
TWILIO_ACCOUNT_SID=your_account_sid_here
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_PHONE_NUMBER=your_twilio_number_here

# Test Recipient
TEST_SMS_RECIPIENT=your_number_here
